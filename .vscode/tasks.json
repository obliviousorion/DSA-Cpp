{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run",
            "type": "shell",
            "command": "./run", 
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "g++ -O3 main.cpp -o main.exe && main.exe < input.txt > output.txt && type output.txt"
                ]
            },
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        }
    ]
}